# ── Modo do app ──────────────────────────────────────────────────────────────
# Com NEXT_PUBLIC_API_URL definido  -> MODO API (produto real, consome a FastAPI).
# Sem ele (ex.: no deploy Vercel)    -> MODO DEMO (mock), com os dados de src/lib/data.ts.
#
# Copie para .env.local para desenvolver em modo API.

NEXT_PUBLIC_API_URL=http://localhost:9090

# Chave de projeto usada em dev (o /login também aceita colar a chave manualmente).
# Gere em Configurações -> Chaves de API do seu projeto (ou no seed do backend).
NEXT_PUBLIC_DEV_API_KEY=proj_sua_chave_de_projeto_aqui
